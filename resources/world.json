    "pcstudent": {
      "questId": "pcstudent",
      "questText": "Na monitoru svítí nápis: Pro přístup zadej správné slovo.\nNápověda: Jsem začátek i konec abecedy. Bez mě bys nic nenapsal. Co jsem?\nZadej odpověď jedním slovem.",
      "answer": "pismeno",
      "state": "NOT_STARTED"
    },
    "spravcedilny": {
      "questId": "spravcedilny",
      "questText": "Správce dílny: Než ti něco dám, řekni mi jednu věc.\nJaký předmět si bereš na ruce, když pracuješ v dílně?\nNapiš odpověď jedním slovem.",
      "answer": "rukavice",
